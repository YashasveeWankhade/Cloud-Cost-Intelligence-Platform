# ─── Copy this file to .env and fill in your values ────────────────────────
# cp .env.example .env
#
# .env is git-ignored. Never commit real secrets.
# ────────────────────────────────────────────────────────────────────────────

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars

# ── Cloud Provider ────────────────────────────────────────────────────────────
# mock  → synthetic data, no AWS account needed (default)
# aws   → real AWS Cost Explorer / CloudWatch / CloudTrail (see AWS section below)
CLOUD_PROVIDER=mock

# ── Gemini AI (optional) ─────────────────────────────────────────────────────
# Leave as demo-key to use rule-based recommendation templates.
# Set a real key from https://aistudio.google.com/app/apikey to enable AI.
GEMINI_API_KEY=demo-key
GEMINI_ENABLED=false

# ── Email Notifications (optional) ───────────────────────────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# For Gmail: use an App Password (not your account password)
MAIL_PASSWORD=

# ── AWS Credentials (only needed when CLOUD_PROVIDER=aws) ────────────────────
# The IAM user/role needs read-only access to:
#   - ce:GetCostAndUsage          (Cost Explorer)
#   - cloudwatch:GetMetricData    (CloudWatch)
#   - cloudtrail:LookupEvents     (CloudTrail)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Database (default works with docker-compose, change for external DBs) ────
POSTGRES_PASSWORD=postgres
